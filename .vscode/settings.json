{
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": "docker-compose.yml"
  },
  "python.analysis.typeCheckingMode": "basic",
  "editor.formatOnSave": true,
  "[python]": {
    "editor.tabSize": 4
  },
  "[yaml]": {
    "editor.tabSize": 2
  }
}
